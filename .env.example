# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB=gemscout

# Voyage AI (for embeddings)
VOYAGE_API_KEY=your_voyage_api_key_here

# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini (direct API, optional fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# FastAPI
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
BACKEND_CORS_ORIGINS=http://localhost:5173,https://your-frontend.run.app

# Migration (source PostgreSQL, only needed for migrate_to_mongodb.py)
POSTGRES_DSN=postgresql://user:password@localhost:5432/openmercat
